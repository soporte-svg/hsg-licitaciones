# =============================================================================
# HSG Licitaciones — Variables de entorno
# Copia este archivo a .env y completa los valores. No subas .env al repositorio.
# =============================================================================

# --- Frontend (Vite; prefijo VITE_ expuesto al navegador) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Vacío en local → proxy /api → LICITACIONES_API_PORT. En prod: URL pública del API.
VITE_API_URL=

# --- API Node ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
LICITACIONES_API_PORT=3100
# En prod: URL del front en Vercel (varias separadas por coma si hay previews)
LICITACIONES_WEB_ORIGIN=http://localhost:5173
# Solo si el API está en OTRO host (Opción B). En monolito Vercel déjala vacía.
# VITE_API_URL=https://tu-api.onrender.com

# En Vercel (monolito): pega el JSON del service account (no uses ruta a secrets/)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# --- Inteligencia artificial (LLM_PROVIDER=anthropic | openai) ---
LLM_PROVIDER=anthropic

# Anthropic (si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (si LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# Opcionales IA
# LLM_TIMEOUT_MS=300000
# LLM_MAX_TOKENS_ANALISIS_EXTENDIDO=16384
# ANTHROPIC_MAX_TOKENS_ANALISIS_EXTENDIDO=16384

# Límites del comparador
# COMPARAR_MAX_PDFS_PER_PROVEEDOR=6
# COMPARAR_MAX_PDF_BYTES=4194304

# --- Google Drive (service account, solo lectura) ---
DRIVE_CREDENTIALS_JSON=./secrets/tu-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=id_carpeta_raiz_propuestas
GOOGLE_DRIVE_TERMINOS_FOLDER_ID=id_carpeta_central_terminos

# Alternativa: JSON inline (menos habitual)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
