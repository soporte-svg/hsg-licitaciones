{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/[[...route]].ts": {
      "maxDuration": 60,
      "memory": 2048
    },
    "api/health.ts": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
