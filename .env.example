# Copia a .env (no lo subas al repo).

# --- Navegador (Vite) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
# Vacío en local = proxy Vite /api → LICITACIONES_API_PORT (3100). En prod, URL del API.
VITE_API_URL=

# --- API Node (licitaciones/server) ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
# IA del comparador: anthropic (default) | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...
# Opcional; default claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
# Si LLM_PROVIDER=openai:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
LICITACIONES_API_PORT=3100
LICITACIONES_WEB_ORIGIN=http://localhost:5173

# --- Google Drive ---
DRIVE_CREDENTIALS_JSON=./secrets/tu-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=tu_carpeta_raiz_de_drive
GOOGLE_DRIVE_TERMINOS_FOLDER_ID=1EBHgOv2o9O1WR8yOBu5NFRrd16nCOP2V
